[Unit]
Description=Continuous audio recording service
After=network.target sound.target
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/opt/noiseport/app
EnvironmentFile=/opt/noiseport/config/sensor.env
Environment="PYTHONPATH=/opt/noiseport/app"
ExecStart=/bin/bash /opt/noiseport/app/Automatize/01_recording.sh
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target